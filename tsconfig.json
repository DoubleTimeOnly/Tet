{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "app",
    "lib",
    "db",
    "services",
    "adapters",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
